@model finalProject.Models.Course

@{
    ViewData["Title"] = "Course Details";
}

<div class="row justify-content-center">

    <div class="col-lg-8">

        <div class="card shadow-sm">

            <div class="card-header bg-primary text-white">

                <h3 class="mb-0">
                    <i class="fas fa-book me-2"></i>
                    Course Details
                </h3>

            </div>

            <div class="card-body">

                <div class="text-center mb-4">

                    <div class="rounded-circle bg-primary text-white d-inline-flex
                        align-items-center justify-content-center"
                         style="width:90px;height:90px;font-size:32px;">

                        <i class="fas fa-book"></i>

                    </div>

                    <h2 class="mt-3">
                        @Model.CourseName
                    </h2>

                    <p class="text-muted">
                        Academic Course Information
                    </p>

                </div>

                <hr />

                <table class="table table-bordered">

                    <tr>
                        <th width="30%">Course ID</th>
                        <td>#@Model.CourseId</td>
                    </tr>

                    <tr>
                        <th>Course Name</th>
                        <td>@Model.CourseName</td>
                    </tr>

                    <tr>
                        <th>Credit Hours</th>
                        <td>
                            <span class="px-3 py-1 rounded border bg-light text-dark">
                                @Model.CreditHours Hours
                            </span>
                        </td>
                    </tr>

                    <tr>
                        <th>Department</th>
                        <td>
                            @(Model.Department?.DepartmentName ?? "Not Assigned")
                        </td>
                    </tr>

                </table>

            </div>

            <div class="card-footer text-end">

                <a asp-action="Index"
                   class="btn btn-secondary">

                    <i class="fas fa-arrow-left me-1"></i>
                    Back

                </a>

                <a asp-action="Edit"
                   asp-route-id="@Model.CourseId"
                   class="btn btn-warning">

                    <i class="fas fa-edit me-1"></i>
                    Edit

                </a>

            </div>

        </div>

    </div>

</div>