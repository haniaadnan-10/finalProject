@model finalProject.Models.Course

@{
    ViewData["Title"] = "Edit Course";
}

<div class="row justify-content-center">

    <div class="col-lg-8">

        <div class="card shadow-sm">

            <div class="card-header bg-warning">

                <h3 class="mb-0 text-dark">
                    <i class="fas fa-edit me-2"></i>
                    Edit Course
                </h3>

            </div>

            <div class="card-body">

                <form asp-action="Edit">

                    <div asp-validation-summary="ModelOnly"
                         class="alert alert-danger">
                    </div>

                    <input type="hidden" asp-for="CourseId" />

                    <div class="mb-4">

                        <label asp-for="CourseName"
                               class="form-label">
                            Course Name
                        </label>

                        <input asp-for="CourseName"
                               class="form-control"
                               placeholder="Enter course name" />

                        <span asp-validation-for="CourseName"
                              class="text-danger"></span>

                    </div>

                    <div class="row">

                        <div class="col-md-6 mb-3">

                            <label asp-for="CreditHours"
                                   class="form-label">
                                Credit Hours
                            </label>

                            <select asp-for="CreditHours"
                                    class="form-select">

                                <option value="1">1 Hour</option>
                                <option value="2">2 Hours</option>
                                <option value="3">3 Hours</option>
                                <option value="4">4 Hours</option>

                            </select>

                            <span asp-validation-for="CreditHours"
                                  class="text-danger"></span>

                        </div>

                        <div class="col-md-6 mb-3">

                            <label asp-for="DepartmentId"
                                   class="form-label">
                                Department
                            </label>

                            <select asp-for="DepartmentId"
                                    asp-items="ViewBag.DepartmentId"
                                    class="form-select">

                                <option value="">
                                    Select Department
                                </option>

                            </select>

                            <span asp-validation-for="DepartmentId"
                                  class="text-danger"></span>

                        </div>

                    </div>

                    <hr class="my-4" />

                    <div class="text-end">

                        <a asp-action="Index"
                           class="btn btn-secondary me-2">

                            <i class="fas fa-arrow-left me-1"></i>
                            Cancel

                        </a>

                        <button type="submit"
                                class="btn btn-warning">

                            <i class="fas fa-save me-1"></i>
                            Update Course

                        </button>

                    </div>

                </form>

            </div>

        </div>

    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}