@model finalProject.Models.Enrollment

@{
    ViewData["Title"] = "New Enrollment";
}

<div class="row justify-content-center">

    <div class="col-lg-8">

        <div class="card shadow-sm">

            <div class="card-header bg-primary text-white">

                <h3 class="mb-0">
                    <i class="fas fa-user-plus me-2"></i>
                    Create New Enrollment
                </h3>

            </div>

            <div class="card-body">

                <form asp-action="Create">

                    <div asp-validation-summary="ModelOnly"
                         class="alert alert-danger">
                    </div>

                    <div class="row">

                        <div class="col-md-6 mb-3">

                            <label asp-for="StudentId"
                                   class="form-label">
                                Student
                            </label>

                            <select asp-for="StudentId"
                                    asp-items="ViewBag.StudentId"
                                    class="form-select">

                                <option value="">
                                    Select Student
                                </option>

                            </select>

                            <span asp-validation-for="StudentId"
                                  class="text-danger"></span>

                        </div>

                        <div class="col-md-6 mb-3">

                            <label asp-for="CourseId"
                                   class="form-label">
                                Course
                            </label>

                            <select asp-for="CourseId"
                                    asp-items="ViewBag.CourseId"
                                    class="form-select">

                                <option value="">
                                    Select Course
                                </option>

                            </select>

                            <span asp-validation-for="CourseId"
                                  class="text-danger"></span>

                        </div>

                    </div>

                    <div class="row">

                        <div class="col-md-6 mb-3">

                            <label asp-for="Semester"
                                   class="form-label"></label>

                            <select asp-for="Semester"
                                    class="form-select">

                                <option value="">
                                    Select Semester
                                </option>

                                <option>Spring 2026</option>
                                <option>Summer 2026</option>
                                <option>Fall 2026</option>

                            </select>

                            <span asp-validation-for="Semester"
                                  class="text-danger"></span>

                        </div>

                        <div class="col-md-6 mb-3">

                            <label asp-for="Grade"
                                   class="form-label"></label>

                            <select asp-for="Grade"
                                    class="form-select">

                                <option value="">
                                    Not Assigned Yet
                                </option>

                                <option>A+</option>
                                <option>A</option>
                                <option>B+</option>
                                <option>B</option>
                                <option>C+</option>
                                <option>C</option>
                                <option>D</option>
                                <option>F</option>

                            </select>

                            <span asp-validation-for="Grade"
                                  class="text-danger"></span>

                        </div>

                    </div>

                    <hr class="my-4" />

                    <div class="text-end">

                        <a asp-action="Index"
                           class="btn btn-secondary me-2">

                            <i class="fas fa-arrow-left me-1"></i>
                            Cancel

                        </a>

                        <button type="submit"
                                class="btn btn-success">

                            <i class="fas fa-save me-1"></i>
                            Save Enrollment

                        </button>

                    </div>

                </form>

            </div>

        </div>

    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}