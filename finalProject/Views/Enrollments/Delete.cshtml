@model finalProject.Models.Enrollment

@{
    ViewData["Title"] = "Delete Enrollment";
}

<div class="row justify-content-center">

    <div class="col-lg-8">

        <div class="card border-danger shadow-sm">

            <div class="card-header bg-danger text-white">

                <h3 class="mb-0">
                    <i class="fas fa-exclamation-triangle me-2"></i>
                    Confirm Enrollment Deletion
                </h3>

            </div>

            <div class="card-body">

                <div class="alert alert-warning">

                    <h5 class="mb-2">
                        Are you sure you want to delete this enrollment?
                    </h5>

                    <p class="mb-0">
                        This action cannot be undone.
                    </p>

                </div>

                <table class="table table-bordered">

                    <tr>
                        <th width="30%">Enrollment ID</th>
                        <td>#@Model.EnrollmentId</td>
                    </tr>

                    <tr>
                        <th>Student</th>
                        <td>
                            @(Model.Student?.FirstName + " " + Model.Student?.LastName)
                        </td>
                    </tr>

                    <tr>
                        <th>Course</th>
                        <td>
                            @Model.Course?.CourseName
                        </td>
                    </tr>

                    <tr>
                        <th>Semester</th>
                        <td>
                            <span class="badge bg-primary">
                                @Model.Semester
                            </span>
                        </td>
                    </tr>

                    <tr>
                        <th>Grade</th>
                        <td>
                            <span class="badge bg-success">
                                @(Model.Grade ?? "Not Assigned")
                            </span>
                        </td>
                    </tr>

                </table>

            </div>

            <div class="card-footer text-end">

                <form asp-action="Delete">

                    <input type="hidden"
                           asp-for="EnrollmentId" />

                    <a asp-action="Index"
                       class="btn btn-secondary me-2">

                        <i class="fas fa-arrow-left me-1"></i>
                        Cancel

                    </a>

                    <button type="submit"
                            class="btn btn-danger">

                        <i class="fas fa-trash me-1"></i>
                        Delete Enrollment

                    </button>

                </form>

            </div>

        </div>

    </div>

</div>