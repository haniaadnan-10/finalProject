@model finalProject.Models.Enrollment

@{
    ViewData["Title"] = "Enrollment Details";
}

<div class="row justify-content-center">

    <div class="col-lg-8">

        <div class="card shadow-sm">

            <div class="card-header bg-info text-white">

                <h3 class="mb-0">
                    <i class="fas fa-book-reader me-2"></i>
                    Enrollment Details
                </h3>

            </div>

            <div class="card-body">

                <div class="text-center mb-4">

                    <div class="rounded-circle bg-primary text-white d-inline-flex
                        align-items-center justify-content-center"
                         style="width:90px;height:90px;font-size:32px;">

                        #@Model.EnrollmentId

                    </div>

                    <h3 class="mt-3">
                        Enrollment Record
                    </h3>

                    <p class="text-muted">
                        Complete enrollment information
                    </p>

                </div>

                <hr />

                <table class="table table-bordered">

                    <tr>
                        <th width="30%">Student</th>
                        <td>
                            @(Model.Student?.FirstName + " " + Model.Student?.LastName)
                        </td>
                    </tr>

                    <tr>
                        <th>Course</th>
                        <td>
                            @Model.Course?.CourseName
                        </td>
                    </tr>

                    <tr>
                        <th>Semester</th>
                        <td>
                            <span class="px-3 py-1 rounded border bg-light text-dark">
                                @Model.Semester
                            </span>
                        </td>
                    </tr>

                    <tr>
                        <th>Grade</th>
                        <td>
                            <span class="px-3 py-1 rounded border bg-light text-dark">
                                @(Model.Grade ?? "Not Assigned")
                            </span>
                        </td>
                    </tr>

                </table>

            </div>

            <div class="card-footer text-end">

                <a asp-action="Index"
                   class="btn btn-secondary">

                    <i class="fas fa-arrow-left me-1"></i>
                    Back

                </a>

                <a asp-action="Edit"
                   asp-route-id="@Model.EnrollmentId"
                   class="btn btn-warning">

                    <i class="fas fa-edit me-1"></i>
                    Edit

                </a>

            </div>

        </div>

    </div>

</div>