@model IEnumerable<finalProject.Models.Enrollment>

@{
    ViewData["Title"] = "Enrollment Records";
}

<div class="card shadow-sm">

    <div class="card-header d-flex justify-content-between align-items-center">

        <h3 class="card-title mb-0">
            <i class="fas fa-clipboard-list me-2"></i>
            Enrollment Records
        </h3>

        <a asp-action="Create" class="btn btn-primary">
            <i class="fas fa-plus me-1"></i>
            New Enrollment
        </a>

    </div>

    <div class="card-body">

        <table id="enrollmentTable"
               class="table table-hover table-striped align-middle">

            <thead class="table-light">

                <tr>
                    <th>ID</th>
                    <th>Student</th>
                    <th>Course</th>
                    <th>Semester</th>
                    <th>Grade</th>
                    <th class="text-center">Actions</th>
                </tr>

            </thead>

            <tbody>

                @foreach (var item in Model)
                {
                    <tr>

                        <td>
                            #@item.EnrollmentId
                        </td>

                        <td>
                            <strong>
                                @item.Student?.FirstName
                                @item.Student?.LastName
                            </strong>
                        </td>

                        <td>
                            @item.Course?.CourseName
                        </td>

                        <td>
                            <span class="badge bg-primary px-3 py-2">
                                @item.Semester
                            </span>
                        </td>

                        <td>

                            @if (!string.IsNullOrEmpty(item.Grade))
                            {
                                <span class="badge bg-success px-3 py-2">
                                    @item.Grade
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-secondary px-3 py-2">
                                    Pending
                                </span>
                            }

                        </td>

                        <td class="text-center">

                            <a asp-action="Edit"
                               asp-route-id="@item.EnrollmentId"
                               class="btn btn-warning btn-sm mx-1"
                               title="Edit">

                                <i class="fas fa-edit"></i>

                            </a>

                            <a asp-action="Details"
                               asp-route-id="@item.EnrollmentId"
                               class="btn btn-info btn-sm mx-1"
                               title="Details">

                                <i class="fas fa-eye"></i>

                            </a>

                            <a asp-action="Delete"
                               asp-route-id="@item.EnrollmentId"
                               class="btn btn-danger btn-sm mx-1"
                               title="Delete">

                                <i class="fas fa-trash"></i>

                            </a>

                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>

</div>

@section Scripts {

    <script>

        $(document).ready(function () {

            $('#enrollmentTable').DataTable({

                responsive: true,
                pageLength: 5,

                lengthMenu: [5, 10, 25, 50],

                language: {

                    search: "Search Enrollments:",
                    lengthMenu: "Show _MENU_ records"

                }

            });

        });

    </script>

}