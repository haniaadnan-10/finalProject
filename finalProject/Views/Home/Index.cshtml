@using finalProject.Models

@{
    ViewData["Title"] = "Dashboard";

    <p class="text-muted mb-4">
        Semester: Spring 2026 | Last Updated: @DateTime.Now.ToString("dd MMM yyyy")
    </p>

    var students = ViewBag.RecentStudents as List<Student>;
    var enrollments = ViewBag.RecentEnrollments as List<Enrollment>;
}

<h2 class="mb-4">
    🎓 Student Management Dashboard
</h2>

<!-- Statistics -->
<div class="row">

    <div class="col-md-2">
        <div class="card text-center shadow">
            <div class="card-body">
                <h1>@ViewBag.TotalStudents</h1>
                <p>Students</p>
            </div>
        </div>
    </div>

    <div class="col-md-2">
        <div class="card text-center shadow">
            <div class="card-body">
                <h1>@ViewBag.TotalDepartments</h1>
                <p>Departments</p>
            </div>
        </div>
    </div>

    <div class="col-md-2">
        <div class="card text-center shadow">
            <div class="card-body">
                <h1>@ViewBag.TotalCourses</h1>
                <p>Courses</p>
            </div>
        </div>
    </div>

    <div class="col-md-2">
        <div class="card text-center shadow">
            <div class="card-body">
                <h1>@ViewBag.TotalTeachers</h1>
                <p>Teachers</p>
            </div>
        </div>
    </div>

    <div class="col-md-2">
        <div class="card text-center shadow">
            <div class="card-body">
                <h1>@ViewBag.TotalEnrollments</h1>
                <p>Enrollments</p>
            </div>
        </div>
    </div>

</div>

<!-- Management Shortcuts -->
<div class="card shadow-sm mb-4">

    <div class="card-header">
        <h4 class="mb-0">
            Management Shortcuts
        </h4>
    </div>

    <div class="card-body">

        <div class="d-flex gap-3 flex-wrap">

            <a asp-controller="Students"
               asp-action="Create"
               class="btn btn-primary">
                <i class="fas fa-user-plus"></i>
                Add Student
            </a>

            <a asp-controller="Teachers"
               asp-action="Create"
               class="btn btn-success">
                <i class="fas fa-chalkboard-teacher"></i>
                Add Teacher
            </a>

            <a asp-controller="Courses"
               asp-action="Create"
               class="btn btn-warning">
                <i class="fas fa-book"></i>
                Add Course
            </a>

            <a asp-controller="Enrollments"
               asp-action="Create"
               class="btn btn-danger">
                <i class="fas fa-clipboard-list"></i>
                New Enrollment
            </a>

        </div>

    </div>

</div>

<!-- Second Row -->
<div class="row mt-4">

    <!-- Recent Students -->
    <div class="col-md-6">

        <div class="card shadow">

            <div class="card-header">
                <h5>Recent Students</h5>
            </div>

            <div class="card-body">

                <table class="table table-striped">

                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Name</th>
                        </tr>
                    </thead>

                    <tbody>

                        @foreach (var s in students)
                        {
                            <tr>
                                <td>@s.StudentId</td>
                                <td>@s.FirstName @s.LastName</td>
                            </tr>
                        }

                    </tbody>

                </table>

            </div>

        </div>

    </div>

    <!-- Recent Enrollments -->
    <div class="col-md-6">

        <div class="card shadow">

            <div class="card-header">
                <h5>Recent Enrollments</h5>
            </div>

            <div class="card-body">

                <table class="table table-striped">

                    <thead>
                        <tr>
                            <th>Student</th>
                            <th>Course</th>
                        </tr>
                    </thead>

                    <tbody>

                        @foreach (var e in enrollments)
                        {
                            <tr>
                                <td>@e.Student?.FirstName @e.Student?.LastName</td>
                                <td>@e.Course?.CourseName</td>
                            </tr>
                        }

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>


