<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - Student Management System</title>

    <link rel="stylesheet" href="~/dist/css/adminlte.min.css" />

</head>

<body class="layout-fixed sidebar-expand-lg bg-body-tertiary">

    <div class="app-wrapper">

        <!-- Header -->
        <nav class="app-header navbar navbar-expand bg-body">
            <div class="container-fluid">
                <a class="navbar-brand" href="/">Student Management System</a>
            </div>
        </nav>

        <!-- Sidebar -->
        <aside class="app-sidebar bg-body-secondary shadow" data-bs-theme="dark">

            <div class="sidebar-brand">
                <a asp-controller="Home" asp-action="Index"
                   class="brand-link text-decoration-none">
                    <span class="brand-text fw-light">
                        SMS
                    </span>
                </a>
            </div>

            <div class="sidebar-wrapper">
                <nav class="mt-2">

                    <ul class="nav sidebar-menu flex-column">

                        <li class="nav-item">
                            <a asp-controller="Home"
                               asp-action="Index"
                               class="nav-link">
                                Dashboard
                            </a>
                        </li>

                        <li class="nav-item">
                            <a asp-controller="Students"
                               asp-action="Index"
                               class="nav-link">
                                Students
                            </a>
                        </li>

                        <li class="nav-item">
                            <a asp-controller="Departments"
                               asp-action="Index"
                               class="nav-link">
                                Departments
                            </a>
                        </li>

                        <li class="nav-item">
                            <a asp-controller="Courses"
                               asp-action="Index"
                               class="nav-link">
                                Courses
                            </a>
                        </li>

                        <li class="nav-item">
                            <a asp-controller="Teachers"
                               asp-action="Index"
                               class="nav-link">
                                Teachers
                            </a>
                        </li>

                        <li class="nav-item">
                            <a asp-controller="Enrollments"
                               asp-action="Index"
                               class="nav-link">
                                Enrollments
                            </a>
                        </li>

                    </ul>

                </nav>
            </div>

        </aside>

        <!-- Main Content -->
        <main class="app-main">

            <div class="container-fluid p-4">
                @RenderBody()
            </div>

        </main>

    </div>

    <script src="~/dist/js/adminlte.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>