@model finalProject.Models.Student

@{
    ViewData["Title"] = "Student Details";
}

<div class="row justify-content-center">

    <div class="col-lg-8">

        <div class="card shadow-sm">

            <div class="card-header bg-info text-white">

                <h3 class="mb-0">
                    <i class="fas fa-user-graduate me-2"></i>
                    Student Details
                </h3>

            </div>

            <div class="card-body">

                <div class="text-center mb-4">

                    <div class="rounded-circle bg-primary text-white d-inline-flex
                        align-items-center justify-content-center"
                         style="width:90px;height:90px;font-size:32px;">

                        @Model.FirstName[0]@Model.LastName[0]

                    </div>

                    <h3 class="mt-3 mb-0">
                        @Model.FirstName @Model.LastName
                    </h3>

                    <p class="text-muted">
                        Student ID: #@Model.StudentId
                    </p>

                </div>

                <hr />

                <div class="row">

                    <div class="col-md-6 mb-4">

                        <h6 class="text-primary">
                            <i class="fas fa-user me-2"></i>
                            Personal Information
                        </h6>

                        <table class="table table-borderless">

                            <tr>
                                <th>Gender:</th>
                                <td>@Model.Gender</td>
                            </tr>

                            <tr>
                                <th>Date of Birth:</th>
                                <td>@Model.DateOfBirth</td>
                            </tr>

                            <tr>
                                <th>Department:</th>
                                <td>
                                    @(Model.Department?.DepartmentName ?? "N/A")
                                </td>
                            </tr>

                        </table>

                    </div>

                    <div class="col-md-6 mb-4">

                        <h6 class="text-success">
                            <i class="fas fa-address-book me-2"></i>
                            Contact Information
                        </h6>

                        <table class="table table-borderless">

                            <tr>
                                <th>Email:</th>
                                <td>@Model.Email</td>
                            </tr>

                            <tr>
                                <th>Phone:</th>
                                <td>@Model.Phone</td>
                            </tr>

                            <tr>
                                <th>Address:</th>
                                <td>@Model.Address</td>
                            </tr>

                        </table>

                    </div>

                </div>

            </div>

            <div class="card-footer text-end">

                <a asp-action="Index"
                   class="btn btn-secondary">

                    <i class="fas fa-arrow-left me-1"></i>
                    Back

                </a>

                <a asp-action="Edit"
                   asp-route-id="@Model.StudentId"
                   class="btn btn-warning">

                    <i class="fas fa-edit me-1"></i>
                    Edit

                </a>

            </div>

        </div>

    </div>

</div>