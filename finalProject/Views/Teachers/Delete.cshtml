@model finalProject.Models.Teacher

@{
    ViewData["Title"] = "Delete Teacher";
}

<div class="row justify-content-center">

    <div class="col-lg-8">

        <div class="card shadow border-danger">

            <div class="card-header bg-danger text-white">

                <h3 class="mb-0">
                    <i class="fas fa-user-times me-2"></i>
                    Delete Teacher
                </h3>

            </div>

            <div class="card-body">

                <div class="alert alert-warning">

                    <i class="fas fa-exclamation-triangle me-2"></i>
                    Are you sure you want to permanently delete this teacher?

                </div>

                <div class="row g-4">

                    <div class="col-md-6">

                        <div class="border rounded p-3 h-100">

                            <small class="text-muted">Teacher Name</small>

                            <h5 class="mt-2">
                                @Model.TeacherName
                            </h5>

                        </div>

                    </div>

                    <div class="col-md-6">

                        <div class="border rounded p-3 h-100">

                            <small class="text-muted">Email Address</small>

                            <h5 class="mt-2">
                                @Model.Email
                            </h5>

                        </div>

                    </div>

                    <div class="col-12">

                        <div class="border rounded p-3">

                            <small class="text-muted">Department</small>

                            <h5 class="mt-2">
                                @(Model.Department?.DepartmentName ?? "Not Assigned")
                            </h5>

                        </div>

                    </div>

                </div>

                <hr class="my-4" />

                <form asp-action="Delete">

                    <input type="hidden" asp-for="TeacherId" />

                    <div class="text-end">

                        <a asp-action="Index"
                           class="btn btn-secondary me-2">

                            <i class="fas fa-arrow-left me-1"></i>
                            Cancel

                        </a>

                        <button type="submit"
                                class="btn btn-danger">

                            <i class="fas fa-trash me-1"></i>
                            Delete Teacher

                        </button>

                    </div>

                </form>

            </div>

        </div>

    </div>

</div>