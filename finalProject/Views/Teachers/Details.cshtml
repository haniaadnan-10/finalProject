@model finalProject.Models.Teacher

@{
    ViewData["Title"] = "Teacher Details";
}

<div class="row justify-content-center">

    <div class="col-lg-8">

        <div class="card shadow-sm">

            <div class="card-header bg-primary text-white">

                <h3 class="mb-0">
                    <i class="fas fa-user-tie me-2"></i>
                    Teacher Details
                </h3>

            </div>

            <div class="card-body">

                <div class="text-center mb-4">

                    <div class="rounded-circle bg-primary text-white d-inline-flex
                        align-items-center justify-content-center"
                         style="width:90px;height:90px;font-size:32px;">

                        @(Model.TeacherName?.Substring(0, 1).ToUpper())

                    </div>

                    <h3 class="mt-3 mb-0">
                        @Model.TeacherName
                    </h3>

                    <p class="text-muted">
                        Faculty Member
                    </p>

                </div>

                <div class="row g-4">

                    <div class="col-md-6">

                        <div class="border rounded p-3 h-100">

                            <small class="text-muted">
                                Email Address
                            </small>

                            <h5 class="mt-2">
                                @Model.Email
                            </h5>

                        </div>

                    </div>

                    <div class="col-md-6">

                        <div class="border rounded p-3 h-100">

                            <small class="text-muted">
                                Department
                            </small>

                            <h5 class="mt-2">
                                @(Model.Department?.DepartmentName ?? "Not Assigned")
                            </h5>

                        </div>

                    </div>

                    <div class="col-12">

                        <div class="border rounded p-3">

                            <small class="text-muted">
                                Teacher ID
                            </small>

                            <h5 class="mt-2">
                                #@Model.TeacherId
                            </h5>

                        </div>

                    </div>

                </div>

                <hr class="my-4" />

                <div class="text-end">

                    <a asp-action="Index"
                       class="btn btn-secondary me-2">

                        <i class="fas fa-arrow-left me-1"></i>
                        Back

                    </a>

                    <a asp-action="Edit"
                       asp-route-id="@Model.TeacherId"
                       class="btn btn-primary">

                        <i class="fas fa-edit me-1"></i>
                        Edit Teacher

                    </a>

                </div>

            </div>

        </div>

    </div>

</div>