@model finalProject.Models.Teacher

@{
    ViewData["Title"] = "Edit Teacher";
}

<div class="row justify-content-center">

    <div class="col-lg-8">

        <div class="card shadow-sm">

            <div class="card-header bg-warning text-dark">

                <h3 class="mb-0">
                    <i class="fas fa-user-edit me-2"></i>
                    Edit Teacher
                </h3>

            </div>

            <div class="card-body">

                <form asp-action="Edit">

                    <div asp-validation-summary="ModelOnly"
                         class="alert alert-danger">
                    </div>

                    <input type="hidden" asp-for="TeacherId" />

                    <div class="mb-4">

                        <label asp-for="TeacherName"
                               class="form-label">
                            Teacher Name
                        </label>

                        <input asp-for="TeacherName"
                               class="form-control"
                               placeholder="Enter teacher name" />

                        <span asp-validation-for="TeacherName"
                              class="text-danger"></span>

                    </div>

                    <div class="mb-4">

                        <label asp-for="Email"
                               class="form-label">
                            Email Address
                        </label>

                        <input asp-for="Email"
                               type="email"
                               class="form-control"
                               placeholder="teacher@university.com" />

                        <span asp-validation-for="Email"
                              class="text-danger"></span>

                    </div>

                    <div class="mb-4">

                        <label asp-for="DepartmentId"
                               class="form-label">
                            Department
                        </label>

                        <select asp-for="DepartmentId"
                                asp-items="ViewBag.DepartmentId"
                                class="form-select">

                            <option value="">
                                Select Department
                            </option>

                        </select>

                        <span asp-validation-for="DepartmentId"
                              class="text-danger"></span>

                    </div>

                    <hr class="my-4" />

                    <div class="text-end">

                        <a asp-action="Index"
                           class="btn btn-secondary me-2">

                            <i class="fas fa-arrow-left me-1"></i>
                            Cancel

                        </a>

                        <button type="submit"
                                class="btn btn-warning">

                            <i class="fas fa-save me-1"></i>
                            Update Teacher

                        </button>

                    </div>

                </form>

            </div>

        </div>

    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}